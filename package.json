{
	"name": "athene-genealogy",
	"version": "0.9.5",
	"description": "ID registry, file creation modal and Templater integration for genealogical data management.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"check-i18n": "node scripts/check-translations.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage"
	},
	"keywords": [
		"obsidian",
		"genealogy",
		"id-registry",
		"templater"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.17",
		"@vitest/coverage-v8": "^4.1.4",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"edtf": "^4.11.0",
		"i18next": "^26.0.5",
		"obsidian": "latest"
	}
}
